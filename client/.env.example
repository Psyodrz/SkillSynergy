# Copy to .env and fill in values. Never commit .env or .env.local.
# Production: set the same keys in your Vercel project (Settings → Environment Variables).

VITE_API_URL=http://localhost:5005
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay public key only (must match payment-backend RAZORPAY_KEY_ID)
VITE_RAZORPAY_KEY_ID=rzp_test_OR_live_YOUR_KEY_ID

# Firebase (optional — use your Firebase console values)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
